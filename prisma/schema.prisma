// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  FLEET_MANAGER
  DISPATCHER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum LicenseCategory {
  TRUCK
  VAN
  BIKE
}

enum DriverStatus {
  ON_DUTY
  OFF_DUTY
  ON_TRIP
  SUSPENDED
}

enum VehicleType {
  TRUCK
  VAN
  BIKE
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  OUT_OF_SERVICE
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum ServiceType {
  OIL_CHANGE
  TIRE_ROTATION
  BRAKE_SERVICE
  ENGINE_REPAIR
  OTHER
}

enum IncidentType {
  ACCIDENT
  TRAFFIC_VIOLATION
  LATE_DELIVERY
  CARGO_DAMAGE
}

enum Severity {
  LOW // score_deduction: 5
  MEDIUM // score_deduction: 15
  HIGH // score_deduction: 25
}

model User {
  id           String  @id @default(uuid())
  email        String  @unique @db.VarChar(100)
  passwordHash String  @map("password_hash") @db.VarChar(255)
  firstName    String  @db.VarChar(100)
  lastName     String? @db.VarChar(100)
  role         Role
  isActive     Boolean @default(true) @map("is_active")

  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  trips              Trip[]
  maintenanceRecords MaintenanceRecord[]
  fuelLogs           FuelLog[]
  incidents          Incident[]

  @@map("users")
}

model Driver {
  id                String          @id @default(uuid())
  firstName         String          @map("first_name") @db.VarChar(100)
  lastName          String?         @map("last_name") @db.VarChar(100)
  phone             String          @unique @db.Char(10)
  licenseNumber     String          @unique @map("license_number") @db.VarChar(50)
  licenseExpiryDate DateTime        @map("license_expiry_date") @db.Date
  licenseCategory   LicenseCategory @map("license_category")
  status            DriverStatus    @default(ON_DUTY)
  safetyScore       Decimal         @default(100.00) @map("safety_score") @db.Decimal(5, 2)
  totalTrips        Int             @default(0) @map("total_trips")
  completedTrips    Int             @default(0) @map("completed_trips")

  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  trips     Trip[]
  incidents Incident[]

  @@map("drivers")
}

model Vehicle {
  id                String        @id @default(uuid())
  name              String        @db.VarChar(100)
  model             String?       @db.VarChar(100)
  licensePlate      String        @unique @map("license_plate") @db.VarChar(20)
  type              VehicleType
  maxLoadCapacityKg Decimal       @map("max_load_capacity_kg") @db.Decimal(10, 2)
  currentOdometerKm Decimal       @default(0) @map("current_odometer_km") @db.Decimal(10, 2)
  status            VehicleStatus @default(AVAILABLE)
  acquisitionCost   Decimal?      @map("acquisition_cost") @db.Decimal(12, 2)

  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  trips              Trip[]
  maintenanceRecords MaintenanceRecord[]
  fuelLogs           FuelLog[]

  @@map("vehicles")
}

model Trip {
  id                 String     @id @default(uuid())
  vehicleId          String     @map("vehicle_id")
  driverId           String     @map("driver_id")
  cargoDescription   String?    @map("cargo_description") @db.Text
  cargoWeightKg      Decimal    @map("cargo_weight_kg") @db.Decimal(10, 2)
  origin             String     @db.VarChar(255)
  destination        String     @db.VarChar(255)
  plannedDeparture   DateTime?  @map("planned_departure")
  actualStart        DateTime?  @map("actual_start")
  actualEnd          DateTime?  @map("actual_end")
  startOdometerKm    Decimal?   @map("start_odometer_km") @db.Decimal(10, 2)
  endOdometerKm      Decimal?   @map("end_odometer_km") @db.Decimal(10, 2)
  status             TripStatus @default(DRAFT)
  revenue            Decimal?   @db.Decimal(10, 2)
  cancellationReason String?    @map("cancellation_reason") @db.Text
  createdBy          String?    @map("created_by")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  vehicle   Vehicle    @relation(fields: [vehicleId], references: [id])
  driver    Driver?    @relation(fields: [driverId], references: [id])
  creator   User?      @relation(fields: [createdBy], references: [id])
  fuelLogs  FuelLog[]
  incidents Incident[]

  @@map("trips")
}

model MaintenanceRecord {
  id          String      @id @default(uuid())
  vehicleId   String      @map("vehicle_id")
  serviceType ServiceType @map("service_type")
  description String?     @db.Text
  cost        Decimal     @db.Decimal(10, 2)
  serviceDate DateTime    @map("service_date") @db.Date
  vendor      String?     @db.VarChar(255)
  isCompleted Boolean     @default(false) @map("is_completed")
  createdBy   String      @map("created_by")
  createdAt   DateTime    @default(now()) @map("created_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  creator User    @relation(fields: [createdBy], references: [id])

  @@map("maintenance_records")
}

model FuelLog {
  id               String   @id @default(uuid())
  vehicleId        String   @map("vehicle_id")
  tripId           String?  @map("trip_id")
  liters           Decimal  @db.Decimal(10, 3)
  costPerLiter     Decimal  @map("cost_per_liter") @db.Decimal(10, 4)
  totalCost        Decimal  @map("total_cost") @db.Decimal(10, 2)
  odometerAtFillKm Decimal? @map("odometer_at_fill_km") @db.Decimal(10, 2)
  fuelDate         DateTime @map("fuel_date") @db.Date
  createdBy        String   @map("created_by")
  createdAt        DateTime @default(now()) @map("created_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  trip    Trip?   @relation(fields: [tripId], references: [id])
  creator User    @relation(fields: [createdBy], references: [id])

  @@map("fuel_logs")
}

model Incident {
  id             String       @id @default(uuid())
  driverId       String       @map("driver_id")
  tripId         String?      @map("trip_id")
  incidentType   IncidentType @map("incident_type")
  severity       Severity
  scoreDeduction Decimal      @map("score_deduction") @db.Decimal(5, 2)
  incidentDate   DateTime     @map("incident_date") @db.Date
  createdBy      String       @map("created_by")
  createdAt      DateTime     @default(now()) @map("created_at")

  // Relations
  driver  Driver @relation(fields: [driverId], references: [id])
  trip    Trip?  @relation(fields: [tripId], references: [id])
  creator User   @relation(fields: [createdBy], references: [id])

  @@map("incidents")
}
